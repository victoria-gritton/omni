{
  "name": "@sso/rhythm",
  "version": "1.3.0",
  "description": "SSO Rhythm — Glass-themed UI primitives, tokens, and Tailwind plugin",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
    ".": "./index.js",
    "./plugin": "./plugin.cjs",
    "./tokens": "./tokens.cjs",
    "./preset.css": "./preset.css",
    "./components/*": "./src/components/*",
    "./steering/*": "./steering/*"
  },
  "files": [
    "index.js",
    "plugin.cjs",
    "tokens.cjs",
    "preset.css",
    "src/components/**/*.jsx",
    "src/components/**/*.js",
    "src/components/**/*.css",
    "docs/",
    "steering/"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "@phosphor-icons/react": { "optional": true },
    "react-router-dom": { "optional": true },
    "react-chartjs-2": { "optional": true },
    "chart.js": { "optional": true },
    "ag-grid-react": { "optional": true },
    "ag-grid-community": { "optional": true },
    "motion": { "optional": true },
    "highcharts": { "optional": true },
    "highcharts-react-official": { "optional": true },
    "react-resizable-panels": { "optional": true }
  },
  "keywords": ["design-system", "tailwind", "react", "glass", "ui"]
}
